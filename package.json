{
  "name": "chatgpt-token-counter",
  "description": "Count tokens in real time on chatgpt conversation",
  "private": false,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:all": "bun run zip && bun run zip:firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@wxt-dev/i18n": "^0.2.5",
    "gpt-tokenizer": "^3.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "wxt": "^0.20.25"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "esbuild",
    "spawn-sync"
  ]
}
